{
  "name": "bridges-toolkit",
  "version": "1.0.0",
  "description": "A Figma desktop plugin for auditing text styles and extracting frame copy.",
  "author": "Nikolay Kulikov <@bridgerosepetal>",
  "license": "MIT",
  "packageManager": "pnpm@10.16.0",
  "keywords": [
    "figma",
    "figma-plugin",
    "text-audit",
    "design-tokens",
    "typography",
    "copy-extraction",
    "bridges-toolkit"
  ],
  "dependencies": {
    "@create-figma-plugin/utilities": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@create-figma-plugin/build": "^4.0.3",
    "@create-figma-plugin/tsconfig": "^4.0.3",
    "@figma/plugin-typings": "1.109.0",
    "@tailwindcss/cli": "^4.2.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "preact": "^10.29.2",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "tailwind:build": "tailwindcss -i ./src/app/tailwind.css -o ./src/app/tailwind.generated.css",
    "tailwind:watch": "tailwindcss -i ./src/app/tailwind.css -o ./src/app/tailwind.generated.css --watch",
    "build": "build-figma-plugin --typecheck --minify",
    "watch": "build-figma-plugin --typecheck --watch",
    "check": "build-figma-plugin --typecheck"
  },
  "figma-plugin": {
    "editorType": [
      "figma"
    ],
    "id": "bridges-toolkit",
    "name": "Bridges Toolkit",
    "main": {
      "src": "src/app/plugin/main.ts",
      "handler": "default"
    },
    "ui": {
      "src": "src/app/UiEntry.ts",
      "handler": "renderRunUi"
    },
    "menu": [
      {
        "name": "Run",
        "main": {
          "src": "src/app/plugin/main.ts",
          "handler": "default"
        },
        "ui": {
          "src": "src/app/UiEntry.ts",
          "handler": "renderRunUi"
        }
      },
      {
        "name": "Diagnostics",
        "main": {
          "src": "src/app/plugin/main.ts",
          "handler": "diagnostics"
        }
      }
    ]
  }
}
